generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Song {
  id                   String   @id
  title                String
  artist               String
  genre                String?
  album                String?
  year                 Int?
  chord_data           String
  contributor_username String?
  source               String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([title])
  @@index([artist])
  @@index([genre])
}
